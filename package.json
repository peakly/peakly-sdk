{
  "name": "peakly",
  "version": "1.0.1",
  "description": "Auto-generated TypeScript SDK for the Peakly API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "bash scripts/generate.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.4"
  },
  "devDependencies": {
    "@semantic-release/git": "^10.0.1",
    "openapi-typescript": "^7.4.4",
    "semantic-release": "^25.0.5",
    "typescript": "^5.5.4",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peakly/peakly-sdk.git"
  },
  "license": "MIT"
}
